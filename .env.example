# ──────────────────────────────────────────────────────────────────────────────
# FusionCameraDataService — Environment Variables
# Copy this file to .env and fill in the values for your node.
# ──────────────────────────────────────────────────────────────────────────────

# ┌─────────────────────────────────────────────────────────────────────────────
# │ REQUIRED
# └─────────────────────────────────────────────────────────────────────────────

# Unique identifier for THIS gateway node / digital-twin.
# Consumers MUST include this exact value in every API request URL.
# Example: twin-factory-line-01  |  robot-arm-cell-03  |  conveyor-belt-07
DEVICE_ID=your-unique-device-id-here


# ┌─────────────────────────────────────────────────────────────────────────────
# │ SERVER
# └─────────────────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=5443

# Enable or disable debug mode (never use true in production)
DEBUG=false

# Number of gunicorn worker processes (1 is fine; cameras use threads)
WORKERS=1

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ┌─────────────────────────────────────────────────────────────────────────────
# │ TLS / HTTPS
# └─────────────────────────────────────────────────────────────────────────────

SSL_ENABLED=true

# When true the service generates a self-signed cert on first start.
# Set to false and provide real cert/key paths for production.
SSL_SELF_SIGNED=true

# Validity period of the auto-generated cert (days)
SSL_CERT_DAYS=3650

SSL_CERT_PATH=/app/certs/cert.pem
SSL_KEY_PATH=/app/certs/key.pem


# ┌─────────────────────────────────────────────────────────────────────────────
# │ CAMERA / STREAMING
# └─────────────────────────────────────────────────────────────────────────────

# Target stream resolution (camera must support it; falls back to native)
STREAM_WIDTH=1280
STREAM_HEIGHT=720

# Maximum frames per second delivered to clients
STREAM_FPS=30

# JPEG encode quality for stream frames (1 = smallest/worst, 100 = largest/best)
STREAM_JPEG_QUALITY=85

# Maximum /dev/videoN device index to probe (0 to MAX_CAMERAS-1)
MAX_CAMERAS=10

# Seconds to wait before retrying a disconnected camera
CAMERA_RECONNECT_DELAY=2.0
