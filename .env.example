# ──────────────────────────────────────────────────────────────────────────────
# FusionCameraDataService — Environment Variables
# Copy this file to .env and fill in the values for your node.
# ──────────────────────────────────────────────────────────────────────────────

# ┌─────────────────────────────────────────────────────────────────────────────
# │ REQUIRED
# └─────────────────────────────────────────────────────────────────────────────

# Unique identifier for THIS gateway node / digital-twin.
# Sent with every pushed frame so NestJS servers know the source.
# Example: twin-factory-line-01  |  robot-arm-cell-03  |  conveyor-belt-07
DEVICE_ID=your-unique-device-id-here

# Comma-separated list of NestJS socket.io endpoint base URLs to push frames to.
# All listed targets receive every frame from every active camera.
# Example: http://nest-server-1:3000
# Example (multi-target): http://nest1:3000,http://nest2:3000
PUSH_TARGETS=http://your-nestjs-server:3000


# ┌─────────────────────────────────────────────────────────────────────────────
# │ PUSH CONFIGURATION
# └─────────────────────────────────────────────────────────────────────────────

# socket.io server path on the NestJS server (default matches NestJS default)
PUSH_PATH=/socket.io

# socket.io namespace declared on the NestJS @WebSocketGateway({ namespace: ... })
PUSH_NAMESPACE=/camera

# Frames per second to push to each target (independent of capture rate)
# Recommended: keep this ≤ STREAM_FPS and set based on your network bandwidth
PUSH_FPS=15

# Shared secret sent in the socket.io handshake auth payload.
# NestJS validates this in handleConnection() or a guard.
# Leave empty to disable secret authentication (not recommended in production).
PUSH_SECRET=

# Seconds to wait before retrying a failed connection to a push target
PUSH_RECONNECT_DELAY=5.0


# ┌─────────────────────────────────────────────────────────────────────────────
# │ CAMERA SELECTION
# └─────────────────────────────────────────────────────────────────────────────

# Comma-separated /dev/videoN indices to capture and push.
# Leave empty to auto-scan and push ALL accessible cameras.
# Example (explicit): CAMERA_INDICES=0,1,2
CAMERA_INDICES=


# ┌─────────────────────────────────────────────────────────────────────────────
# │ CAMERA CAPTURE
# └─────────────────────────────────────────────────────────────────────────────

# Capture resolution (camera negotiates closest match)
STREAM_WIDTH=1280
STREAM_HEIGHT=720

# Internal capture frame rate of the camera capture thread
STREAM_FPS=30

# JPEG encode quality for every pushed frame (1 = smallest/worst, 100 = largest/best)
STREAM_JPEG_QUALITY=85

# Maximum /dev/videoN device index to probe during auto-scan
MAX_CAMERAS=10

# Seconds to wait before re-opening a disconnected camera
CAMERA_RECONNECT_DELAY=2.0


# ┌─────────────────────────────────────────────────────────────────────────────
# │ HEALTH SERVER  (k3s liveness / readiness probes — no consumer traffic)
# └─────────────────────────────────────────────────────────────────────────────

# Port for the internal HTTP health server
# Endpoints: /health  /ready  /metrics
HEALTH_PORT=9090


# ┌─────────────────────────────────────────────────────────────────────────────
# │ LOGGING
# └─────────────────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
